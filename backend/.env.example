# AI providers — at least one required
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional fallback

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Session store — leave blank to use in-memory (local dev)
# Set both for production (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Supabase — optional, enables auth + history
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase backend persistence (service role key — keep secret, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key    # same value as VITE_SUPABASE_ANON_KEY, used by admin routes

# Razorpay payments
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_PLAN_ID_INR=plan_...   # ₹749/month plan
RAZORPAY_PLAN_ID_USD=plan_...   # $9/month plan

# Frontend — set to your backend URL in production (e.g. Render)
VITE_API_BASE=http://localhost:8001
