# AI Providers (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Supabase frontend (anon key — safe to expose via Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase backend (service role key — never expose to frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=    # same value as VITE_SUPABASE_ANON_KEY, used by backend (admin routes)

# Session store (optional — in-memory fallback used locally)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay payments
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_INR=plan_...   # ₹749/month plan
RAZORPAY_PLAN_ID_USD=plan_...   # $9/month plan

# Stripe (optional, not used)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
FRONTEND_URL=http://localhost:5173
